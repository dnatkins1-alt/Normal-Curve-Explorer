const HIST_MAX_X = 18;

function drawHistogram(svgId, bins, opts) {
  const svg = document.getElementById(svgId);
  if (!svg) return;
  const padding = opts.padding || 40;
  const viewWidth = opts.viewWidth;
  const viewHeight = opts.viewHeight;
  const axisY = viewHeight - padding;
  const topY = 20;
  const usableHeight = axisY - topY;
  const usableWidth = viewWidth - 2 * padding;
  const binWidth = usableWidth / bins.length;
  const maxBin = opts.maxBin || Math.max(...bins);
  const barColor = opts.barColor || 'rgba(31,78,121,0.55)';
  const barStroke = opts.barStroke || '#1F4E79';
  
  while (svg.firstChild) svg.removeChild(svg.firstChild);
  const NS = 'http://www.w3.org/2000/svg';
  
  for (let i = 0; i < bins.length; i++) {
    if (bins[i] === 0) continue;
    const x = padding + i * binWidth;
    const h = (bins[i] / maxBin) * usableHeight;
    const y = axisY - h;
    const rect = document.createElementNS(NS, 'rect');
    rect.setAttribute('x', x.toFixed(2));
    rect.setAttribute('y', y.toFixed(2));
    rect.setAttribute('width', (binWidth - 1).toFixed(2));
    rect.setAttribute('height', h.toFixed(2));
    rect.setAttribute('fill', barColor);
    rect.setAttribute('stroke', barStroke);
    rect.setAttribute('stroke-width', '0.5');
    svg.appendChild(rect);
  }
  
  const axisLine = document.createElementNS(NS, 'line');
  axisLine.setAttribute('x1', padding);
  axisLine.setAttribute('y1', axisY);
  axisLine.setAttribute('x2', viewWidth - padding);
  axisLine.setAttribute('y2', axisY);
  axisLine.setAttribute('stroke', '#666');
  axisLine.setAttribute('stroke-width', '1.5');
  svg.appendChild(axisLine);
  
  const tickValues = opts.tickValues || [0, 5, 10, 15];
  for (const t of tickValues) {
    const x = padding + (t / HIST_MAX_X) * usableWidth;
    const tick = document.createElementNS(NS, 'line');
    tick.setAttribute('x1', x); tick.setAttribute('y1', axisY);
    tick.setAttribute('x2', x); tick.setAttribute('y2', axisY + 4);
    tick.setAttribute('stroke', '#666');
    svg.appendChild(tick);
    const label = document.createElementNS(NS, 'text');
    label.setAttribute('x', x); label.setAttribute('y', axisY + 14);
    label.setAttribute('text-anchor', 'middle');
    label.setAttribute('font-size', '10');
    label.setAttribute('font-family', 'Calibri,sans-serif');
    label.setAttribute('fill', '#666');
    label.textContent = t;
    svg.appendChild(label);
  }
  
  const xtitle = document.createElementNS(NS, 'text');
  xtitle.setAttribute('x', viewWidth / 2);
  xtitle.setAttribute('y', viewHeight - 4);
  xtitle.setAttribute('text-anchor', 'middle');
  xtitle.setAttribute('font-size', '11');
  xtitle.setAttribute('font-family', 'Calibri,sans-serif');
  xtitle.setAttribute('fill', '#666');
  xtitle.textContent = 'Days absent';
  svg.appendChild(xtitle);
  
  const ytitle = document.createElementNS(NS, 'text');
  ytitle.setAttribute('x', 12);
  ytitle.setAttribute('y', viewHeight / 2);
  ytitle.setAttribute('text-anchor', 'middle');
  ytitle.setAttribute('font-size', '11');
  ytitle.setAttribute('font-family', 'Calibri,sans-serif');
  ytitle.setAttribute('fill', '#666');
  ytitle.setAttribute('transform', 'rotate(-90 12 ' + (viewHeight / 2) + ')');
  ytitle.textContent = 'Number of employees';
  svg.appendChild(ytitle);
  
  if (opts.overlay) {
    const { mean, sd, n } = opts.overlay;
    let d = '';
    const points = 200;
    for (let i = 0; i <= points; i++) {
      const x_val = HIST_MAX_X * i / points;
      const z = (x_val - mean) / sd;
      const density = normPDF(z) / sd;
      const expected_count = density * 1 * n;
      const x_px = padding + (x_val / HIST_MAX_X) * usableWidth;
      const y_px = axisY - (expected_count / maxBin) * usableHeight;
      d += (i === 0 ? 'M' : 'L') + x_px.toFixed(2) + ',' + y_px.toFixed(2) + ' ';
    }
    const curve = document.createElementNS(NS, 'path');
    curve.setAttribute('d', d);
    curve.setAttribute('fill', 'none');
    curve.setAttribute('stroke', '#782F40');
    curve.setAttribute('stroke-width', '2.5');
    svg.appendChild(curve);
  }
}

