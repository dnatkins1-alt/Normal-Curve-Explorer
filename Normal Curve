  });
  const svg = document.getElementById(key + '-chart');
  let dragging = false;
  function pxToData(clientX) {
    const r = svg.getBoundingClientRect();
    const px = (clientX - r.left) / r.width * CHART.W;
    return XMIN + (px - CHART.ML) / CHART.PW * (XMAX - XMIN);
