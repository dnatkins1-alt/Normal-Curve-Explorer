const FULL_VIEW = { W: 800, H: 220, ML: 40, MR: 16, MT: 16, MB: 32 };
FULL_VIEW.PW = FULL_VIEW.W - FULL_VIEW.ML - FULL_VIEW.MR;
FULL_VIEW.PH = FULL_VIEW.H - FULL_VIEW.MT - FULL_VIEW.MB;
const FULL_XMIN = 0, FULL_XMAX = 18, FULL_BW = 1;

function binDataGeneric(data, xmin, xmax, bw) {
  const nb = (xmax - xmin) / bw;
  const bins = new Array(nb).fill(0);
  data.forEach(v => {
    let i = Math.floor((v - xmin) / bw);
    if (i >= nb) i = nb - 1;
    if (i < 0) i = 0;
    bins[i]++;
  });
  return bins;
}

function pdfAtX(x, mean, sd) {
  const z = (x - mean) / sd;
  return Math.exp(-0.5 * z * z) / (sd * Math.sqrt(2 * Math.PI));
}

function drawFullChart() {
  const svg = document.getElementById('full-chart');
  while (svg.firstChild) svg.removeChild(svg.firstChild);
  const NS = 'http://www.w3.org/2000/svg';
  function elem(tag, attrs) {
    const e = document.createElementNS(NS, tag);
    for (const k in attrs) e.setAttribute(k, attrs[k]);
    return e;
  }
  
  const bins = binDataGeneric(FULL.data, FULL_XMIN, FULL_XMAX, FULL_BW);
  const maxBin = Math.max(...bins);
  const curvePeak = pdfAtX(FULL.mean, FULL.mean, FULL.sd) * FULL_BW * FULL.n;
  const yMax = Math.max(maxBin, curvePeak) * 1.08;
  
  const xS = v => FULL_VIEW.ML + (v - FULL_XMIN) / (FULL_XMAX - FULL_XMIN) * FULL_VIEW.PW;
  const yS = c => FULL_VIEW.MT + FULL_VIEW.PH - (c / yMax) * FULL_VIEW.PH;
  
  const loEdge = FULL.mean - FULL.zRange * FULL.sd;
  const hiEdge = FULL.mean + FULL.zRange * FULL.sd;
  
  // Histogram bars (mark bars within the band differently)
  bins.forEach((c, i) => {
    const x0 = FULL_XMIN + i * FULL_BW;
    const xCenter = x0 + FULL_BW/2;
    const inBand = (xCenter >= loEdge && xCenter <= hiEdge);
    svg.appendChild(elem('rect', {
      x: xS(x0) + 0.5,
      y: yS(c),
      width: (xS(x0 + FULL_BW) - xS(x0)) - 1,
      height: yS(0) - yS(c),
      class: 'hist-bar' + (inBand ? ' in-band' : '')
    }));
  });
  
  // Shaded band area under curve (lo to hi)
  let bandD = 'M' + xS(loEdge).toFixed(2) + ',' + yS(0).toFixed(2);
  for (let i = 0; i <= 80; i++) {
    const x = loEdge + (hiEdge - loEdge) * i / 80;
    const y = pdfAtX(x, FULL.mean, FULL.sd) * FULL_BW * FULL.n;
    bandD += 'L' + xS(x).toFixed(2) + ',' + yS(y).toFixed(2);
  }
  bandD += 'L' + xS(hiEdge).toFixed(2) + ',' + yS(0).toFixed(2) + ' Z';
  svg.appendChild(elem('path', { d: bandD, fill: 'rgba(31,78,121,0.22)' }));
  
  // Normal curve
  let curveD = '';
  for (let i = 0; i <= 120; i++) {
    const x = FULL_XMIN + (FULL_XMAX - FULL_XMIN) * i / 120;
    const y = pdfAtX(x, FULL.mean, FULL.sd) * FULL_BW * FULL.n;
    curveD += (i === 0 ? 'M' : 'L') + xS(x).toFixed(2) + ',' + yS(y).toFixed(2);
  }
  svg.appendChild(elem('path', { d: curveD, class: 'curve-blue' }));
  
  // Mean line
  svg.appendChild(elem('line', {
    x1: xS(FULL.mean), y1: FULL_VIEW.MT, x2: xS(FULL.mean), y2: yS(0), class: 'mean-line'
  }));
  
  // Vertical band lines (two symmetric lines)
  if (loEdge >= FULL_XMIN) {
    svg.appendChild(elem('line', {
      x1: xS(loEdge), y1: FULL_VIEW.MT, x2: xS(loEdge), y2: yS(0), class: 'cutoff-line-blue'
    }));
  }
  if (hiEdge <= FULL_XMAX) {
    svg.appendChild(elem('line', {
      x1: xS(hiEdge), y1: FULL_VIEW.MT, x2: xS(hiEdge), y2: yS(0), class: 'cutoff-line-blue'
    }));
  }
  
  // X-axis
  svg.appendChild(elem('line', {
    x1: FULL_VIEW.ML, y1: yS(0), x2: FULL_VIEW.W - FULL_VIEW.MR, y2: yS(0),
    stroke: '#888', 'stroke-width': 1.2
  }));
  for (let v = 0; v <= 18; v += 3) {
    const lbl = elem('text', {
      x: xS(v), y: yS(0) + 14, 'text-anchor': 'middle', class: 'axis-label'
    });
    lbl.textContent = v;
    svg.appendChild(lbl);
  }
  const xt = elem('text', {
    x: FULL_VIEW.ML + FULL_VIEW.PW/2, y: FULL_VIEW.H - 4, 'text-anchor': 'middle', class: 'axis-title'
  });
  xt.textContent = 'Days absent';
  svg.appendChild(xt);
}

function updateFullPanel() {
  const z = FULL.zRange;
  const lo = FULL.mean - z * FULL.sd;
  const hi = FULL.mean + z * FULL.sd;
  const modelPct = (2 * normCDF(z) - 1) * 100;
  const modelN = (modelPct / 100) * FULL.n;
  const actualN = FULL.data.filter(v => v >= lo && v <= hi).length;
  const actualPct = (actualN / FULL.n) * 100;
  
  document.getElementById('full-ro-z').textContent = '±' + z.toFixed(2);
  document.getElementById('full-ro-range').textContent = lo.toFixed(2) + ' to ' + hi.toFixed(2);
  document.getElementById('full-ro-modelpct').innerHTML = modelPct.toFixed(1) + '<small>%</small>';
  document.getElementById('full-ro-modeln').textContent = 'about ' + Math.round(modelN) + ' of 500';
  document.getElementById('full-ro-actual').textContent = actualN;
  document.getElementById('full-ro-actualpct').textContent = actualPct.toFixed(1) + '% of 500';
  
  document.getElementById('full-slider-value').textContent = '±' + z.toFixed(1);
  document.getElementById('full-slider').value = z;
  
  const diff = actualN - Math.round(modelN);
  let fitText;
  if (Math.abs(diff) <= 5) {
    fitText = 'The normal model is a close match for the data at this Z-distance.';
  } else if (diff > 0) {
    fitText = 'The actual count is higher than the model predicts by ' + diff + ' employees.';
  } else {
    fitText = 'The actual count is lower than the model predicts by ' + Math.abs(diff) + ' employees.';
  }
  
  document.getElementById('full-interp').innerHTML =
    'At <span class="v">Z = ±' + z.toFixed(2) + '</span>, the band runs from ' +
    '<strong>' + lo.toFixed(2) + ' to ' + hi.toFixed(2) + ' days</strong>. ' +
    'The normal model predicts <strong>' + modelPct.toFixed(1) + '%</strong> of employees fall within the band ' +
    '(about ' + Math.round(modelN) + ' of 500). The actual count in the childcare pilot data is <strong>' + actualN + '</strong>. ' +
    fitText;
  
  drawFullChart();
}

function setupFullPanel() {
  document.getElementById('full-slider').addEventListener('input', e => {
    FULL.zRange = parseFloat(e.target.value);
    updateFullPanel();
  });
  document.querySelectorAll('[data-chips="full"] .chip').forEach(chip => {
    chip.addEventListener('click', () => {
      FULL.zRange = parseFloat(chip.dataset.z);
      updateFullPanel();
    });
  });
  // Drag on chart adjusts the band symmetrically (distance from mean)
  const svg = document.getElementById('full-chart');
  let dragging = false;
  function pxToData(clientX) {
    const r = svg.getBoundingClientRect();
    const px = (clientX - r.left) / r.width * FULL_VIEW.W;
    return FULL_XMIN + (px - FULL_VIEW.ML) / FULL_VIEW.PW * (FULL_XMAX - FULL_XMIN);
  }
  function startDrag(e) { dragging = true; moveDrag(e); }
  function moveDrag(e) {
    if (!dragging) return;
    const cx = e.touches ? e.touches[0].clientX : e.clientX;
    const xVal = pxToData(cx);
    const z = Math.abs(xVal - FULL.mean) / FULL.sd;
    FULL.zRange = Math.max(0.1, Math.min(3.5, z));
    updateFullPanel();
    if (e.preventDefault) e.preventDefault();
  }
  svg.addEventListener('pointerdown', startDrag);
  window.addEventListener('pointermove', moveDrag);
  window.addEventListener('pointerup', () => { dragging = false; });
}

