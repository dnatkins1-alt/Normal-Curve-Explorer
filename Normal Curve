// ============================================================
// STEP 4 INTERACTIVE CURVE (one curve, mean and SD sliders)
// ============================================================
const IC = { mean: 6.53, sd: 3.66 };
const IC_VIEW = { W: 700, H: 280, ML: 50, MR: 30, MT: 30, MB: 40 };
IC_VIEW.PW = IC_VIEW.W - IC_VIEW.ML - IC_VIEW.MR;
IC_VIEW.PH = IC_VIEW.H - IC_VIEW.MT - IC_VIEW.MB;
const IC_XMIN = 0, IC_XMAX = 24; // give room when mean is near 18

function drawInteractiveCurve() {
  const svg = document.getElementById('interactive-curve-svg');
  while (svg.firstChild) svg.removeChild(svg.firstChild);
  const NS = 'http://www.w3.org/2000/svg';
  function elem(tag, attrs) {
    const e = document.createElementNS(NS, tag);
    for (const k in attrs) e.setAttribute(k, attrs[k]);
    return e;
  }
  
  const xS = v => IC_VIEW.ML + (v - IC_XMIN) / (IC_XMAX - IC_XMIN) * IC_VIEW.PW;
  // Normalize so peak fills the available height regardless of SD
  const peakPDF = normPDF(0) / IC.sd;
  const yS = density => IC_VIEW.MT + IC_VIEW.PH - (density / peakPDF) * IC_VIEW.PH;
  
  // Shaded area under curve
  let shadeD = '';
  const points = 200;
  for (let i = 0; i <= points; i++) {
    const x = IC_XMIN + (IC_XMAX - IC_XMIN) * i / points;
    const z = (x - IC.mean) / IC.sd;
    const density = normPDF(z) / IC.sd;
    shadeD += (i === 0 ? 'M' : 'L') + xS(x).toFixed(2) + ',' + yS(density).toFixed(2) + ' ';
  }
  shadeD += 'L' + xS(IC_XMAX).toFixed(2) + ',' + yS(0).toFixed(2) + ' ';
  shadeD += 'L' + xS(IC_XMIN).toFixed(2) + ',' + yS(0).toFixed(2) + ' Z';
  svg.appendChild(elem('path', { d: shadeD, fill: 'rgba(31,78,121,0.18)' }));
  
  // Curve
  let curveD = '';
  for (let i = 0; i <= points; i++) {
    const x = IC_XMIN + (IC_XMAX - IC_XMIN) * i / points;
    const z = (x - IC.mean) / IC.sd;
    const density = normPDF(z) / IC.sd;
    curveD += (i === 0 ? 'M' : 'L') + xS(x).toFixed(2) + ',' + yS(density).toFixed(2) + ' ';
  }
  svg.appendChild(elem('path', { d: curveD, fill: 'none', stroke: '#1F4E79', 'stroke-width': 2.5 }));
  
  // SD markers (±1 SD and ±2 SD)
  for (let k of [-2, -1, 1, 2]) {
    const xVal = IC.mean + k * IC.sd;
    if (xVal < IC_XMIN || xVal > IC_XMAX) continue;
    const x = xS(xVal);
    svg.appendChild(elem('line', {
      x1: x, y1: IC_VIEW.MT, x2: x, y2: yS(0), class: 'sd-marker'
    }));
    const lbl = elem('text', {
      x: x, y: IC_VIEW.MT - 4, 'text-anchor': 'middle', class: 'sd-label'
    });
    lbl.textContent = (k > 0 ? '+' : '') + k + ' SD';
    svg.appendChild(lbl);
  }
  
  // Mean line
  const meanX = xS(IC.mean);
  svg.appendChild(elem('line', {
    x1: meanX, y1: IC_VIEW.MT, x2: meanX, y2: yS(0), class: 'mean-line', stroke: '#666', 'stroke-width': 1.5
  }));
  const meanLabel = elem('text', {
    x: meanX, y: IC_VIEW.MT - 18, 'text-anchor': 'middle',
    'font-size': 12, 'font-family': 'Calibri,sans-serif', fill: '#666', 'font-weight': 600
  });
  meanLabel.textContent = 'Mean = ' + IC.mean.toFixed(2);
  svg.appendChild(meanLabel);
  
  // X-axis
  svg.appendChild(elem('line', {
    x1: IC_VIEW.ML, y1: yS(0), x2: IC_VIEW.W - IC_VIEW.MR, y2: yS(0), stroke: '#888', 'stroke-width': 1.2
  }));
  for (let v = 0; v <= 24; v += 4) {
    const x = xS(v);
    svg.appendChild(elem('line', { x1: x, y1: yS(0), x2: x, y2: yS(0) + 4, stroke: '#888' }));
    const lbl = elem('text', {
      x: x, y: yS(0) + 17, 'text-anchor': 'middle', class: 'axis-label'
    });
    lbl.textContent = v;
    svg.appendChild(lbl);
  }
  const xt = elem('text', {
    x: IC_VIEW.ML + IC_VIEW.PW/2, y: IC_VIEW.H - 8, 'text-anchor': 'middle', class: 'axis-title'
  });
  xt.textContent = 'Days absent';
  svg.appendChild(xt);
}

function setupInteractiveCurve() {
  const meanSlider = document.getElementById('ic-mean-slider');
  const meanInput = document.getElementById('ic-mean-input');
  const sdSlider = document.getElementById('ic-sd-slider');
  const sdInput = document.getElementById('ic-sd-input');
  
  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
  
  function update(meanVal, sdVal) {
    IC.mean = clamp(meanVal, 0, 18);
    IC.sd = clamp(sdVal, 0.5, 6);
    meanSlider.value = IC.mean;
    meanInput.value = IC.mean.toFixed(2);
    sdSlider.value = IC.sd;
    sdInput.value = IC.sd.toFixed(2);
    drawInteractiveCurve();
  }
  
  meanSlider.addEventListener('input', e => update(parseFloat(e.target.value), IC.sd));
  meanInput.addEventListener('input', e => {
    const v = parseFloat(e.target.value);
    if (!isNaN(v)) update(v, IC.sd);
  });
  sdSlider.addEventListener('input', e => update(IC.mean, parseFloat(e.target.value)));
  sdInput.addEventListener('input', e => {
    const v = parseFloat(e.target.value);
    if (!isNaN(v)) update(IC.mean, v);
  });
  
  // Preset chips
  document.querySelectorAll('.preset-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const m = parseFloat(chip.dataset.mean);
      const s = parseFloat(chip.dataset.sd);
      update(m, s);
    });
  });
  
  drawInteractiveCurve();
}

