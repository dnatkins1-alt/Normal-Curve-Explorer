function updatePanel(key) {
  const p = PANELS[key];
  p.cutoff = Math.max(0, Math.min(18, p.cutoff));
  const z = (p.cutoff - p.mean) / p.sd;
  const tail = 1 - normCDF(z);
  const modelN = tail * p.n;
  const actualN = p.data.filter(v => v > p.cutoff).length;
  
  document.getElementById(key + '-ro-cut').innerHTML = p.cutoff.toFixed(1) + '<small> days</small>';
  document.getElementById(key + '-ro-z').textContent = (z >= 0 ? '+' : '') + z.toFixed(2);
  document.getElementById(key + '-ro-area').innerHTML = (tail * 100).toFixed(1) + '<small>%</small>';
  document.getElementById(key + '-ro-n').textContent = Math.round(modelN);
  document.getElementById(key + '-ro-nsub').textContent = 'model · actual: ' + actualN;
  
  const slider = document.getElementById(key + '-slider');
  const sliderValue = document.getElementById(key + '-slider-value');
  const sliderLabel = document.getElementById(key + '-slider-label');
  if (p.mode === 'cut') {
