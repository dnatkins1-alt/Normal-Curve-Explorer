    slider.value = p.cutoff;
    sliderValue.textContent = p.cutoff.toFixed(1);
    sliderLabel.textContent = 'Cutoff (days)';
  } else {
    slider.min = 1; slider.max = 50; slider.step = 1;
    slider.value = Math.max(1, Math.min(50, Math.round(tail * 100)));
    sliderValue.textContent = Math.round(tail * 100) + '%';
    sliderLabel.textContent = 'Worst %';
  }
  
  const interp = document.getElementById(key + '-interp');
  const dir = z >= 0 ? 'above' : 'below';
  const diff = actualN - Math.round(modelN);
  let fitText = '';
  if (Math.abs(diff) <= 3) {
    fitText = 'The model is a close approximation for this cutoff.';
  } else if (diff > 0) {
    fitText = 'The actual count is higher than the model predicts; the real tail is heavier than normal here.';
  } else {
    fitText = 'The actual count is lower than the model predicts; the real tail is lighter than normal here.';
  }
  interp.innerHTML = 
    'An employee at <span class="v">' + p.cutoff.toFixed(1) + ' days</span> sits ' +
    '<strong>' + Math.abs(z).toFixed(2) + ' SD ' + dir + '</strong> the ' + p.label + ' mean. ' +
    'The normal model says <strong>' + (tail * 100).toFixed(1) + '%</strong> of ' + p.label + ' employees are at or beyond this cutoff: ' +
    'about <strong>' + Math.round(modelN) + ' of ' + p.n + '</strong>. ' +
    'Actual count in the data: <strong>' + actualN + '</strong>. ' + fitText;
  
  drawPanelChart(key);
}

function setupPanel(key) {
